#!/usr/bin/env python3
"""
odoo-ai — one command to gather Odoo ground truth for an AI agent.

Runs the skill's introspection scripts inside `odoo-bin shell`, extracts the
JSON from each, and writes it to an output dir. Instead of three (or four) shell
invocations, the agent (or you) runs ONE command and gets a folder of JSON to
feed in before any code is written.

Config (flags override env):
    --db / ODOO_DB            database name           (required)
    --conf / ODOO_CONF        path to odoo.conf       (optional)
    --odoo-bin / ODOO_BIN     odoo binary             (default: odoo-bin)
    --out-dir                 where JSON is written   (default: /tmp/odoo-ai/<model>)

Commands:
    odoo-ai native-check "<requirement>" [--model M]   # does Odoo already ship this? (Layer H gate-then-rank)
    odoo-ai native-learn "<requirement>" --card <id>   # teach native-check a mapping (learning loop; no DB)
    odoo-ai capabilities <model> | --module <addon>   # native surface (Layer H) — run BEFORE writing code
    odoo-ai feature-map  <model>                       # alias: capabilities for a model
    odoo-ai brief       <model> [--methods a,b] [--source] [--code-preview] [--code]
    odoo-ai entrypoints <model> [--views form,list] [--view-id N] [--view-xmlid m.view]
    odoo-ai metadata    <model>
    odoo-ai trace       <model> <record_id> <method> [--commit]
    odoo-ai state       <model> <record_id> <method> [--break model.method] [--line N] [--fields a,b] [--on-exception] [--redact-extra a,b] [--no-redact]
    odoo-ai security    <model> [--user login_or_id] [--company id_or_name] [--allowed-companies a,b]
    odoo-ai all         <model> [--methods a,b] [--source] [--code-preview] [--code] [--record-id N --method M]

`all` = brief + entrypoints + metadata (+ optional trace when --record-id and
--method are given). It does NOT run refs, preflight, or state — run those
explicitly (refs before a field change, preflight to confirm your code loads,
state for post-mortem locals).

Server-action / cron code bodies are GATED by default (only present/len, no
preview) because even a head-only slice can carry a token, webhook URL, or API
key. Opt in with --code-preview (short head slice) or --code (full bodies) —
trusted context only, and review before pasting into an external LLM.

Examples:
    odoo-ai --db dev all sale.order --methods action_confirm,write,create
    odoo-ai --db dev --conf /etc/odoo.conf all sale.order \
        --methods action_confirm --record-id 42 --method action_confirm
    odoo-ai --db dev trace sale.order 42 action_confirm
    odoo-ai --db dev state sale.order 42 action_confirm --break sale.order._action_confirm --fields state,amount_total
"""
import argparse
import json
import os
import subprocess
import sys
from pathlib import Path

HERE = Path(__file__).resolve().parent          # the skill's scripts/ dir
SCRIPTS = {
    "brief":       (HERE / "model_brief.py", "===ODOO_BRIEF_START===", "===ODOO_BRIEF_END==="),
    "entrypoints": (HERE / "entrypoints.py", "===ODOO_EP_START===",    "===ODOO_EP_END==="),
    "metadata":    (HERE / "metadata.py",    "===ODOO_META_START===",  "===ODOO_META_END==="),
    "trace":       (HERE / "trace_flow.py",  "===ODOO_TRACE_START===", "===ODOO_TRACE_END==="),
    "refs":        (HERE / "field_refs.py",  "===ODOO_REFS_START===",  "===ODOO_REFS_END==="),
    "preflight":   (HERE / "preflight.py",   "===ODOO_PREFLIGHT_START===", "===ODOO_PREFLIGHT_END==="),
    "security":    (HERE / "security_sim.py", "===ODOO_SECURITY_START===", "===ODOO_SECURITY_END==="),
    "state":       (HERE / "state_capture.py", "===ODOO_STATE_START===", "===ODOO_STATE_END==="),
    "capabilities": (HERE / "capabilities.py", "===ODOO_CAP_START===", "===ODOO_CAP_END==="),
    "native_check": (HERE / "native_check.py", "===ODOO_NCHECK_START===", "===ODOO_NCHECK_END==="),
}

# Curated capability cards (consumed by native_check) live in the sibling
# odoo-capabilities skill; resolve the path relative to this CLI so it works in
# both a clone and the installed-plugin layout.
CARDS_DIR = HERE.parent.parent / "odoo-capabilities" / "references" / "cards"


def run_in_shell(script_path, env_extra, cfg):
    cmd = [cfg["odoo_bin"], "shell", "-d", cfg["db"], "--no-http", "--log-level=warn"]
    if cfg.get("conf"):
        cmd += ["-c", cfg["conf"]]
    env = {**os.environ, **{k: str(v) for k, v in env_extra.items()}}
    try:
        with open(script_path) as fh:
            proc = subprocess.run(cmd, stdin=fh, env=env,
                                  capture_output=True, text=True, timeout=cfg["timeout"])
    except FileNotFoundError:
        sys.exit(f"❌ '{cfg['odoo_bin']}' not found. Set --odoo-bin / ODOO_BIN.")
    except subprocess.TimeoutExpired:
        sys.exit(f"❌ Timed out after {cfg['timeout']}s running {script_path.name}.")
    return proc


def extract(stdout, start, end):
    # Take from the FIRST start marker to the LAST end marker (rsplit), so a JSON
    # body that happens to contain the end sentinel (e.g. via --source) doesn't
    # truncate the payload early.
    if start in stdout and end in stdout:
        return stdout.split(start, 1)[1].rsplit(end, 1)[0].strip()
    return None


def do_step(step, env_extra, cfg, out_dir, model):
    script, start, end = SCRIPTS[step]
    proc = run_in_shell(script, env_extra, cfg)
    body = extract(proc.stdout, start, end)
    if body is None:
        tail = (proc.stderr or proc.stdout or "").strip().splitlines()[-8:]
        print(f"  ⚠️  {step}: no JSON returned. Last lines:\n     " + "\n     ".join(tail))
        return None
    try:
        data = json.loads(body)
    except json.JSONDecodeError as e:
        print(f"  ⚠️  {step}: JSON parse failed ({e}).")
        return None
    path = out_dir / f"{model.replace('.', '_')}.{step}.json"
    path.write_text(json.dumps(data, indent=2))
    print(f"  ✓ {step:<11} -> {path}  {_summ(step, data)}")
    return data


def _summ(step, d):
    try:
        if step == "brief":
            return f"({d['field_count']} fields, {len(d['overridden_methods'])} methods)"
        if step == "entrypoints":
            nb = sum(len(v.get("buttons", [])) for v in d.get("views", {}).values()
                     if isinstance(v, dict))
            return f"({nb} buttons, {len(d.get('reports', []))} reports)"
        if step == "metadata":
            return f"({len(d['menu_graph']['menus'])} menu paths, "\
                   f"{len(d['seeded_data'].get('noupdate_records', []))} protected records)"
        if step == "trace":
            sm = d.get("summary", {})
            hot = sm.get("top_self_sql") or []
            extra = f", hot={hot[0]['model']}.{hot[0]['method']}" if hot else ""
            return f"({d['total_addon_calls']} calls, {d['total_sql']} SQL, "\
                   f"{len(d['distinct_steps'])} distinct steps{extra})"
        if step == "refs":
            s = d.get("severity_counts", {})
            return f"({d['reference_count']} refs: {s.get('high', 0)} high / "\
                   f"{s.get('medium', 0)} medium)"
        if step == "preflight":
            m = d.get("module") or {}
            return f"(module found={m.get('found')}, state={m.get('state')}, "\
                   f"{len(d.get('shadow_warnings', []))} shadow warnings)"
        if step == "security":
            ar = d.get("access_rights", {})
            granted = [m for m in ("read", "write", "create", "unlink") if ar.get(m)]
            u = d.get("user", {})
            return f"(user={u.get('login')}, can={'/'.join(granted) or 'none'}, "\
                   f"{len(d.get('field_access', {}).get('restricted', []))} restricted fields)"
        if step == "state":
            return f"({d.get('breakpoint_hits', 0)} snapshots, "\
                   f"{len(d.get('exception_stack', []))} exc frames, "\
                   f"error={'yes' if d.get('error') else 'no'})"
        if step == "capabilities":
            s = d.get("_summary", {})
            if d.get("mode") == "module":
                if not d.get("found") or d.get("state") != "installed":
                    return f"(module={d.get('module')}, not enumerable: "\
                           f"found={d.get('found')}, state={d.get('state')})"
                return f"(module={d.get('module')}, {s.get('models', 0)} models, "\
                       f"{s.get('wizards', 0)} wizards, {s.get('window_actions', 0)} actions, "\
                       f"{s.get('automation_rules', 0)} automations)"
            return f"(model={d.get('model')}, {s.get('functional_fields', 0)} fn-fields, "\
                   f"{s.get('bound_actions', 0)} bound actions, {s.get('reports', 0)} reports)"
        if step == "native_check":
            conf = d.get("confirmed_candidates", [])
            unconf = d.get("unconfirmed_candidates", [])
            top = conf[0]["id"] if conf else "—"
            return f"({len(conf)} present / {len(unconf)} not-here of "\
                   f"{d.get('considered', 0)} matched; top={top})"
    except Exception:
        return ""
    return ""


DEFAULT_LEARN_FILE = Path.home() / ".odoo-ai" / "learned.json"


def resolve_learn_file(arg):
    return Path(arg).expanduser() if arg else DEFAULT_LEARN_FILE


def do_native_learn(requirement, card_id, learn_file):
    """Append a requirement→card mapping to the learn file (the learning loop).

    Pure file op — no DB / odoo shell. `native-check` folds these mappings back
    into the card corpus so a real-world phrasing recalls its card next time.
    """
    learn_file.parent.mkdir(parents=True, exist_ok=True)
    try:
        data = json.loads(learn_file.read_text()) if learn_file.exists() else []
    except Exception:
        data = []
    if not isinstance(data, list):
        data = []
    entry = next((e for e in data if e.get("id") == card_id), None)
    if entry is None:
        entry = {"id": card_id, "learned_intents": []}
        data.append(entry)
    entry.setdefault("learned_intents", [])
    if requirement not in entry["learned_intents"]:
        entry["learned_intents"].append(requirement)
    learn_file.write_text(json.dumps(data, indent=2, ensure_ascii=False) + "\n")
    total = sum(len(e.get("learned_intents", [])) for e in data)
    print(f"✓ learned: {requirement!r} → {card_id}\n  stored in {learn_file}  ({total} mappings total)")


def main():
    p = argparse.ArgumentParser(prog="odoo-ai", description="Gather Odoo ground truth for an AI agent.")
    p.add_argument("--db", default=os.environ.get("ODOO_DB"))
    p.add_argument("--conf", default=os.environ.get("ODOO_CONF"))
    p.add_argument("--odoo-bin", default=os.environ.get("ODOO_BIN", "odoo-bin"))
    p.add_argument("--out-dir")
    p.add_argument("--timeout", type=int, default=600)
    sub = p.add_subparsers(dest="cmd", required=True)

    sc = sub.add_parser("capabilities", help="native capability surface (Layer H) — what this instance already ships; run BEFORE writing code"); sc.add_argument("target", nargs="?", help="a model, e.g. sale.order"); sc.add_argument("--module", help="enumerate everything an addon shipped, e.g. --module sale")
    sfm = sub.add_parser("feature-map", help="alias: capabilities for a model (native surface around it)"); sfm.add_argument("model")
    snc = sub.add_parser("native-check", help="does Odoo already ship this? recall-match curated capability cards, then existence-gate them against this instance (Layer H gate-then-rank)"); snc.add_argument("requirement", help='free-text requirement, e.g. "auto-number delivery slips"'); snc.add_argument("--model", default="", help="optional model for context, e.g. sale.order"); snc.add_argument("--learn-file", default="", help="learned-mappings file to fold in (default: ~/.odoo-ai/learned.json if present)")
    snl = sub.add_parser("native-learn", help="record a solved requirement→card mapping so it recalls next time (the learning loop; no DB needed)"); snl.add_argument("requirement", help="the requirement phrasing that worked"); snl.add_argument("--card", required=True, help="the capability card id it maps to, e.g. sale.down_payment_invoice"); snl.add_argument("--learn-file", default="", help="where to store it (default: ~/.odoo-ai/learned.json)")

    sb = sub.add_parser("brief"); sb.add_argument("model"); sb.add_argument("--methods", default=""); sb.add_argument("--source", action="store_true"); sb.add_argument("--code-preview", dest="code_preview", action="store_true", help="include a short head-only slice of server-action/cron code (potentially sensitive)"); sb.add_argument("--code", action="store_true", help="include FULL server-action/cron code bodies (may contain secrets — trusted context only)")
    se = sub.add_parser("entrypoints"); se.add_argument("model"); se.add_argument("--views", default="form,list"); se.add_argument("--view-id", dest="view_id", default=""); se.add_argument("--view-xmlid", dest="view_xmlid", default="")
    sm = sub.add_parser("metadata"); sm.add_argument("model")
    st = sub.add_parser("trace"); st.add_argument("model"); st.add_argument("record_id"); st.add_argument("method"); st.add_argument("--commit", action="store_true")
    sr = sub.add_parser("refs"); sr.add_argument("model"); sr.add_argument("field"); sr.add_argument("--resolve-paths", dest="resolve_paths", action="store_true", help="graph-resolve dotted depends/related through comodel_name (fewer false positives)")
    sp = sub.add_parser("preflight"); sp.add_argument("module", nargs="?")
    sg = sub.add_parser("security", help="effective ACL + record rules + restricted fields for a user/company"); sg.add_argument("model"); sg.add_argument("--user", default="", help="login or id to simulate (default: current shell user)"); sg.add_argument("--company", default="", help="ACTIVE company id or name (default: user's company)"); sg.add_argument("--allowed-companies", dest="allowed_companies", default="", help="comma-separated company ids/names toggled ON (env.companies; what company_ids resolves to in a rule domain). Default: just --company")
    ss = sub.add_parser("state"); ss.add_argument("model"); ss.add_argument("record_id"); ss.add_argument("method"); ss.add_argument("--break", dest="break_at", default=""); ss.add_argument("--line", dest="break_line"); ss.add_argument("--fields", default=""); ss.add_argument("--on-exception", action="store_true"); ss.add_argument("--max-hits", default="3"); ss.add_argument("--commit", action="store_true"); ss.add_argument("--no-redact", action="store_true", help="disable default redaction of password/token/secret/... (trusted dev box only)"); ss.add_argument("--redact-extra", default="", help="comma-separated extra key names to redact")
    sa = sub.add_parser("all", help="brief + entrypoints + metadata (+ optional trace); NOT refs/preflight/state"); sa.add_argument("model"); sa.add_argument("--methods", default=""); sa.add_argument("--source", action="store_true"); sa.add_argument("--code-preview", dest="code_preview", action="store_true", help="include a short head-only slice of server-action/cron code (potentially sensitive)"); sa.add_argument("--code", action="store_true", help="include FULL server-action/cron code bodies (may contain secrets — trusted context only)"); sa.add_argument("--views", default="form,list"); sa.add_argument("--record-id"); sa.add_argument("--method")

    a = p.parse_args()
    # native-learn is a local file op — no DB / odoo shell needed.
    if a.cmd == "native-learn":
        do_native_learn(a.requirement, a.card, resolve_learn_file(a.learn_file))
        return
    if not a.db:
        sys.exit("❌ No database. Pass --db or set ODOO_DB.")
    cfg = {"db": a.db, "conf": a.conf, "odoo_bin": a.odoo_bin, "timeout": a.timeout}
    # label for the out dir / log line: model for most, module for preflight,
    # target/module for capabilities.
    label = (getattr(a, "model", None) or getattr(a, "module", None)
             or getattr(a, "target", None) or a.cmd)
    out_dir = Path(a.out_dir) if a.out_dir else Path("/tmp/odoo-ai") / str(label).replace(".", "_")
    out_dir.mkdir(parents=True, exist_ok=True)
    print(f"odoo-ai · db={a.db} · target={label} · out={out_dir}")

    if a.cmd == "capabilities":
        if a.module:
            do_step("capabilities", {"MODULE": a.module}, cfg, out_dir, a.module)
        elif a.target:
            do_step("capabilities", {"MODEL": a.target}, cfg, out_dir, a.target)
        else:
            sys.exit("❌ capabilities: pass a model (e.g. `capabilities sale.order`) "
                     "or an addon (`capabilities --module sale`).")
    elif a.cmd == "feature-map":
        do_step("capabilities", {"MODEL": a.model}, cfg, out_dir, a.model)
    elif a.cmd == "native-check":
        env_extra = {"REQUIREMENT": a.requirement, "CARDS_DIR": str(CARDS_DIR)}
        if a.model:
            env_extra["MODEL"] = a.model
        lf = resolve_learn_file(a.learn_file)
        if lf.is_file():
            env_extra["LEARN_FILE"] = str(lf)
        do_step("native_check", env_extra, cfg, out_dir, a.model or "native-check")
    elif a.cmd == "brief":
        do_step("brief", {"MODEL": a.model, "METHODS": a.methods, "SOURCE": "1" if a.source else "",
                          "CODE_PREVIEW": "1" if a.code_preview else "", "CODE": "1" if a.code else ""}, cfg, out_dir, a.model)
    elif a.cmd == "entrypoints":
        env_extra = {"MODEL": a.model, "VIEWS": a.views}
        if a.view_id:
            env_extra["VIEW_ID"] = a.view_id
        if a.view_xmlid:
            env_extra["VIEW_XMLID"] = a.view_xmlid
        do_step("entrypoints", env_extra, cfg, out_dir, a.model)
    elif a.cmd == "metadata":
        do_step("metadata", {"MODEL": a.model}, cfg, out_dir, a.model)
    elif a.cmd == "trace":
        do_step("trace", {"MODEL": a.model, "RECORD_ID": a.record_id, "METHOD": a.method, "COMMIT": "1" if a.commit else ""}, cfg, out_dir, a.model)
    elif a.cmd == "refs":
        do_step("refs", {"MODEL": a.model, "FIELD": a.field, "RESOLVE_PATHS": "1" if a.resolve_paths else ""}, cfg, out_dir, f"{a.model}.{a.field}")
    elif a.cmd == "preflight":
        do_step("preflight", {"MODULE": a.module or ""}, cfg, out_dir, str(label))
    elif a.cmd == "security":
        env_extra = {"MODEL": a.model}
        if a.user:
            env_extra["AS_USER"] = a.user
        if a.company:
            env_extra["AS_COMPANY"] = a.company
        if a.allowed_companies:
            env_extra["AS_ALLOWED_COMPANIES"] = a.allowed_companies
        do_step("security", env_extra, cfg, out_dir, a.model)
    elif a.cmd == "state":
        env_extra = {
            "MODEL": a.model, "RECORD_ID": a.record_id, "METHOD": a.method,
            "BREAK_AT": a.break_at, "FIELDS": a.fields, "MAX_HITS": a.max_hits,
            "COMMIT": "1" if a.commit else "",
        }
        if a.break_line:
            env_extra["BREAK_LINE"] = a.break_line
        if a.on_exception:
            env_extra["ON_EXCEPTION"] = "1"
        if a.no_redact:
            env_extra["NO_REDACT"] = "1"
        if a.redact_extra:
            env_extra["REDACT_EXTRA"] = a.redact_extra
        do_step("state", env_extra, cfg, out_dir, a.model)
    elif a.cmd == "all":
        do_step("brief", {"MODEL": a.model, "METHODS": a.methods, "SOURCE": "1" if a.source else "",
                          "CODE_PREVIEW": "1" if a.code_preview else "", "CODE": "1" if a.code else ""}, cfg, out_dir, a.model)
        do_step("entrypoints", {"MODEL": a.model, "VIEWS": a.views}, cfg, out_dir, a.model)
        do_step("metadata", {"MODEL": a.model}, cfg, out_dir, a.model)
        if a.record_id and a.method:
            do_step("trace", {"MODEL": a.model, "RECORD_ID": a.record_id, "METHOD": a.method}, cfg, out_dir, a.model)
        else:
            print("  · trace skipped (pass --record-id and --method to include the runtime layer)")
        print("  · scope: brief + entrypoints + metadata (+trace). NOT refs/preflight/state — "
              "run `odoo-ai refs|preflight|state` explicitly when you need them.")
    print(f"\nFeed the JSON in {out_dir} to the agent BEFORE asking it to write code.")


if __name__ == "__main__":
    main()
