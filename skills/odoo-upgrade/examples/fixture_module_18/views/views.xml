<odoo>
    <record id="view_contract_form_bestmix" model="ir.ui.view">
        <field name="name">hr.contract.form.bestmix</field>
        <field name="model">hr.contract</field>
        <field name="inherit_id" ref="hr_contract.hr_contract_view_form"/>
        <field name="arch" type="xml">
            <field name="wage" position="after">
                <field name="bestmix_allowance"/>
            </field>
        </field>
    </record>
    <record id="bestmix_default_user_rule" model="ir.rule">
        <field name="name">Fixture rule</field>
        <field name="model_id" ref="hr.model_hr_employee"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>
    <menuitem id="menu_bestmix_expense" name="Bestmix Expense"
              parent="hr_expense.menu_hr_expense_root" groups="base.group_user"/>
</odoo>
